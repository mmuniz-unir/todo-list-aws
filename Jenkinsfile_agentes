pipeline {
    agent any

    options { skipDefaultCheckout() }

     stages {
     
        stage('Get Code') {
            
            steps {
                // Obtener código del repo
                
                git branch: 'develop',
                url: 'https://github.com/mmuniz-unir/todo-list-aws.git'
                stash name:'code', includes:'**'
            }
        }
        
        stage('Static Test') {
        
        
            parallel {
            
            stage ('Flake8') {
                agent { 
                        label 'linux' 
                    }
                steps {
                
                unstash 'code'
                sh '''
                
                flake8 --format=pylint --exit-zero src | tee flake8.out
                
                '''

                }
        }

            stage ('Bandit') {
                agent { 
                        label 'linux' 
                    }
                steps {
                
                unstash name:'code'
                
                sh '''
                
                bandit --exit-zero -r src -f txt | tee bandit.out
                
                '''
                    
                }
        }        
        
        }
    }
        stage('Deploy') {
        
            steps {
                unstash 'code'
                sh '''
                echo "=== SAM Build ==="
                sam build
        
                echo "=== SAM Validate ==="
                sam validate
        
                echo "=== Deploy to Staging ==="
                sam deploy --config-env staging --no-fail-on-empty-changeset || true
                '''
                script {
                    env.BASE_URL = sh(
                        script: "aws cloudformation describe-stacks --stack-name ${STACK_NAME} --query \"Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue\" --output text",
                        returnStdout: true
                    ).trim()
                    echo "API Base URL: ${env.BASE_URL}"
                    
                    // Guardamos la URL en un archivo y lo stasheamos
                    writeFile file: 'base_url.txt', text: env.BASE_URL
                }
                stash name: 'base_url', includes: 'base_url.txt'
            }
        }
        
            
        stage('Rest Test') {
            agent { 
                        label 'linux' 
                    }
            steps {
                unstash 'code'
                unstash 'base_url'
                script {
                    env.BASE_URL = readFile('base_url.txt').trim()
                }
                sh '''
                echo "=== Rest Test Stage (Pytest) ==="
        
                # Obtener URL de la API desde CloudFormation
                BASE_URL=${BASE_URL}
                echo "API Base URL: $BASE_URL"
        
                # Exportamos la variable para Pytest
                export BASE_URL
        
                # Ejecutamos las pruebas de integración con Pytest
                python3 -m pytest test/integration/todoApiTest.py --maxfail=1 --disable-warnings --junitxml=reports/test-results.xml
                '''
                stash includes: 'reports/**', name: 'pytest-results'
            }
        }

        stage('Promote') {
            
            steps {

                echo "=== Promote Stage ==="
        
                withCredentials([usernamePassword(
                    credentialsId: 'github-token', 
                    usernameVariable: 'GIT_USER', 
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        git config --global user.name "Marc Muñiz"
                        git config --global user.email "marcmusuau@gmail.com"
        
                        git config merge.ours.driver true
        
                        git checkout master
                        git pull origin master
        
                        git merge develop --no-ff -m "Promote to master"
        
                        git remote set-url origin https://${GIT_TOKEN}@github.com/mmuniz-unir/todo-list-aws.git
                        git push origin master
                    '''
            
            }
        }
    }    
    }
        post {
        always {
            unstash 'pytest-results'
            junit 'reports/test-results.xml'
            echo 'Cleaning workspace...'
            cleanWs()
        }
    }
}