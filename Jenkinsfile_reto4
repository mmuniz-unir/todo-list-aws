pipeline {
    agent any
    options { skipDefaultCheckout() }

    stages {
        stage('Get Code') {
            steps {
                git branch: 'develop',
                    url: 'https://github.com/mmuniz-unir/todo-list-aws.git'
                stash name:'code', includes:'**'
            }
        }

        stage('Static Test') {
            parallel {
                stage ('Flake8') {
                    agent { label 'linux' }
                    steps {
                        unstash 'code'
                        sh '''
                        echo "Node: $(hostname)"
                        echo "User: $(whoami)" 
                        flake8 --format=pylint --exit-zero src | tee flake8.out
                        '''
                    }
                }
                stage ('Bandit') {
                    agent { label 'linux' }
                    steps {
                        unstash 'code'
                        sh '''
                        echo "Node: $(hostname)"
                        echo "User: $(whoami)" 
                        bandit --exit-zero -r src -f txt | tee bandit.out
                        '''
                    }
                }
            }
        }
    
            stage('Get Configuration') {
            agent { label 'linux' }
            steps {
                sh '''
                    echo "Node: $(hostname)"
                    echo "User: $(whoami)"
                    if [ -d config ]; then
                        cd config && git fetch origin staging && git reset --hard origin/staging
                    else
                        git clone --branch staging https://github.com/mmuniz-unir/todo-list-aws-config.git config
                    fi
                    cp samconfig.toml ..
                    cat samconfig.toml ..
                '''
                stash name: 'samconfig', includes: 'samconfig.toml'
            }
        }

        stage('Deploy') {
            steps {
                unstash 'code'
                unstash 'samconfig'
                script {
                    def STACK_NAME = "staging-todo-list-aws"
                    sh "sam build"
                    sh "sam validate"
                    sh 'echo "Node: $(hostname)"'
                    sh 'echo "User: $(whoami)"'
                    def deployStatus = sh(
                        script: "sam deploy --config-env staging --no-fail-on-empty-changeset",
                        returnStatus: true
                    )
                    echo "Deploy exit code: ${deployStatus}"
                    try {
                        env.BASE_URL = sh(
                            script: "aws cloudformation describe-stacks --stack-name ${STACK_NAME} --query \"Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue\" --output text",
                            returnStdout: true
                        ).trim()
                        echo "API Base URL: ${env.BASE_URL}"
                        writeFile file: 'base_url.txt', text: env.BASE_URL
                        stash name: 'base_url', includes: 'base_url.txt'
                    } catch (err) {
                        echo "No se pudo obtener la URL de la API: ${err}"
                    }
                }
            }
        }

        stage('Rest Test') {
            steps {
                unstash 'code'
                unstash 'base_url'
                script { env.BASE_URL = readFile('base_url.txt').trim() }
                sh '''
                echo "Node: $(hostname)"
                echo "User: $(whoami)"                
                echo "=== Rest Test Stage (Pytest) ==="
                BASE_URL=${BASE_URL}
                export BASE_URL
                python3 -m pytest test/integration/todoApiTest.py --maxfail=1 --disable-warnings --junitxml=reports/test-results.xml
                '''
                stash includes: 'reports/**', name: 'pytest-results'
            }
        }

        stage('Promote') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github-token', 
                    usernameVariable: 'GIT_USER', 
                    passwordVariable: 'GIT_TOKEN'
                )]) {
                    sh '''
                        echo "Node: $(hostname)"
                        echo "User: $(whoami)"
                        git config --global user.name "Marc Muñiz"
                        git config --global user.email "marcmusuau@gmail.com"
                        git config merge.ours.driver true
                        git checkout master
                        git pull origin master
                        git merge develop --no-ff -m "Promote to master"
                        git checkout HEAD -- Jenkinsfile Jenkinsfile_agentes samconfig.toml Jenkinsfile_reto4
                        git remote set-url origin https://${GIT_TOKEN}@github.com/mmuniz-unir/todo-list-aws.git
                        git push origin master
                    '''
                }
            }
        }
    }

    post {
        always {
            unstash 'pytest-results'
            junit 'reports/test-results.xml'
            cleanWs()
        }
    }
}